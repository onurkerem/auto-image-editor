{
  "name": "auto-image-editor",
  "version": "0.1.0",
  "description": "CLI tool for adding text overlays to images",
  "type": "module",
  "bin": {
    "auto-image-editor": "./dist/cli.js"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/cli.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "commander": "^13.1.0",
    "opentype.js": "^1.3.4",
    "sharp": "^0.33.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "@types/opentype.js": "^1.3.4",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0",
    "vitest": "^3.1.0"
  }
}
